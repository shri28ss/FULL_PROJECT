# ─────────────────────────────────────────────
# Supabase Configuration
# ─────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key   # Keep secret — admin use only

# ─────────────────────────────────────────────
# App Settings
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# ML Microservice (Embedding Service)
# ─────────────────────────────────────────────
PYTHON_PORT=5000
# ML_SERVICE_URL=http://127.0.0.1:5000        # Override if ml-service runs elsewhere

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ─────────────────────────────────────────────
# LLM Fallback Configuration (Stage 4)
# Switch provider by changing LLM_PROVIDER to 'openrouter' or 'google'
# ─────────────────────────────────────────────
LLM_PROVIDER=openrouter

# OpenRouter (recommended — one key, many models)
OPENROUTER_API_KEY=your_openrouter_api_key
LLM_MODEL=google/gemini-2.5-flash            # Full model path format for OpenRouter

# Google AI direct (alternative — set LLM_PROVIDER=google to use)
# GOOGLE_API_KEY=your_google_ai_api_key
# LLM_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=INFO                                # DEBUG | INFO | WARN | ERROR
