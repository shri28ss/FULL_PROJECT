# LedgerAI v2.0 Environment Configuration Template
# Copy this file to .env in the appropriate directories and fill in your values
# DO NOT commit .env files with actual secrets to version control

# ============================================
# BACKEND (.env in backend/)
# ============================================

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Backend Server
PORT=3000
NODE_ENV=development

# ML Microservice
PYTHON_PORT=5000

# LLM Configuration
# Provider: 'openrouter' or 'google'
LLM_PROVIDER=openrouter

# OpenRouter API (if using LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key

# Google AI Studio API (if using LLM_PROVIDER=google)
GOOGLE_API_KEY=your_google_api_key

# Model name (provider-specific format)
# OpenRouter: google/gemini-2.0-flash-exp, anthropic/claude-3.5-sonnet, etc.
# Google: gemini-2.0-flash-exp, gemini-1.5-pro, etc.
LLM_MODEL=google/gemini-2.0-flash-exp

# ============================================
# FRONTEND WEB (.env in frontend-web/)
# ============================================

# Supabase Configuration (Vite prefix)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend API URL
VITE_API_BASE_URL=http://localhost:3000

# ============================================
# FRONTEND MOBILE (.env in frontend-mobile/)
# ============================================

# Supabase Configuration (Expo prefix)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend API URL
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ============================================
# ML SERVICE (No .env needed - uses defaults)
# ============================================
# FastAPI service runs on PYTHON_PORT from backend .env
# SpaCy models auto-download on first run
# SentenceTransformers embeddings cached locally

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Create backend/.env with BACKEND values above
# 2. Create frontend-web/.env with FRONTEND WEB values above
# 3. Create frontend-mobile/.env with FRONTEND MOBILE values above
# 4. Obtain credentials from:
#    - Supabase: https://supabase.com/dashboard
#    - OpenRouter: https://openrouter.ai/keys
# 5. Run ./start.sh to start all services
# 6. All .env files are ignored by .gitignore
