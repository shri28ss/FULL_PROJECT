SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
# Service Role Key (Keep this secret! Use only for admin tasks)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
 
# Found in: Supabase Dashboard → Settings → API → JWT Settings
# --- GEMINI API ---
GEMINI_API_KEY=your_gemini_api
# --- MODEL ---
CLASSIFIER_MODEL=models/gemini-2.5-flash
LLM_PARSER_MODEL=models/gemini-2.5-flash
# ── Code Generation LLM ──────────────────────────────────────
# Provider: "anthropic", "openrouter", or "9router"
# Switch between providers by changing this value
# OpenRouter (supports multiple models, moderate cost)
# Get key from: https://openrouter.ai/keys
CODE_GEN_PROVIDER=openrouter
 
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
 
# Code generation settings (applies to all providers)
CODE_GEN_MAX_TOKENS=4096
CODE_GEN_TEMPERATURE=0